{
  "name": "@openmrs/esm-patient-growth-chart-app",
  "version": "1.0.0",
  "license": "MPL-2.0",
  "description": "patient-growth-chart frontend module for O3",
  "browser": "dist/openmrs-esm-patient-growth-chart.js",
  "main": "src/index.ts",
  "source": true,
  "scripts": {
    "start": "openmrs develop",
    "build": "rspack --mode production",
    "build:development": "rspack --mode development",
    "analyze": "rspack --mode=production --env.analyze=true",
    "serve": "rspack serve --mode=development",
    "test": "vitest run --reporter=verbose --passWithNoTests",
    "test:watch": "vitest --reporter=verbose",
    "coverage": "vitest run --coverage",
    "typescript": "tsc",
    "lint": "eslint src --ext ts,tsx",
    "extract-translations": "i18next 'src/**/*.component.tsx' 'src/**/*.extension.tsx' 'src/**/*.modal.tsx' 'src/index.ts' --config ./tools/i18next-parser.config.js",
    "prettier": "prettier --config prettier.config.js --write \"src/**/*.{ts,tsx,css,scss}\"",
    "test-e2e": "playwright test",
    "turbo": "turbo",
    "verify": "turbo run lint typescript test --color --concurrency=5",
    "postinstall": "husky install"
  },
  "keywords": [
    "openmrs",
    "microfrontends"
  ],
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmrs/esm-patient-growth-chart-app.git"
  },
  "bugs": {
    "url": "https://github.com/openmrs/esm-patient-growth-chart-app/issues"
  },
  "homepage": "https://github.com/openmrs/esm-patient-growth-chart-app#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@carbon/charts": "^1.27.3",
    "@carbon/charts-react": "^1.27.3",
    "@carbon/react": "^1.83.0"
  },
  "peerDependencies": {
    "@carbon/react": "1.x",
    "@openmrs/esm-framework": "9.x",
    "dayjs": "1.x",
    "i18next": "25.x",
    "react": "18.x",
    "react-dom": "18.x",
    "react-i18next": "16.x",
    "react-is": "18.x",
    "rxjs": "6.x",
    "sass": "1.x",
    "single-spa": "6.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "@openmrs/esm-framework": "next",
    "@openmrs/rspack-config": "next",
    "@playwright/test": "^1.40.1",
    "@rspack/cli": "^1.7.8",
    "@swc/core": "^1.3.100",
    "@testing-library/jest-dom": "^6.4.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/webpack-env": "^1.18.4",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^4.1.2",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.13",
    "dotenv": "^16.3.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest-dom": "^5.1.0",
    "eslint-plugin-playwright": "^0.15.3",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-testing-library": "^6.2.0",
    "happy-dom": "^18.0.1",
    "husky": "^9.0.11",
    "i18next": "^25.0.0",
    "i18next-parser": "^9.0.1",
    "identity-obj-proxy": "^3.0.0",
    "lint-staged": "^15.2.2",
    "openmrs": "next",
    "prettier": "^3.2.5",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "react-i18next": "^16.0.0",
    "react-is": "^18.3.1",
    "rxjs": "^6.5.3",
    "sass": "^1.33.0",
    "single-spa": "^6.0.0",
    "swr": "^2.0.0",
    "turbo": "^1.11.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --cache --fix --max-warnings 0",
    "*.{css,scss,ts,tsx}": "prettier --write --list-different"
  },
  "packageManager": "yarn@4.10.3"
}
